# Paths
DATA_RAW_PATH=data/raw/ecommerceDataset.csv
DATA_PROCESSED_PATH=data/processed/
MODEL_REGISTRY_PATH=models/registry/

# Model config
MODEL_TYPE=distilbert
MIN_F1_THRESHOLD=0.95

# Database (опционально)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce
DB_USER=user
DB_PASSWORD=password

# Inference
INFERENCE_HOST=0.0.0.0
INFERENCE_PORT=8000

# Training
TRAIN_BATCH_SIZE=32
TRAIN_EPOCHS=4
TRAIN_LEARNING_RATE=5e-5
